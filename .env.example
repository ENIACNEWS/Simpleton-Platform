# ============================================
# SimpletonApp.com Environment Variables
# LaDale Industries LLC
# ============================================

# Database Configuration
DATABASE_URL=your_postgresql_connection_string

# REQUIRED: Session & JWT Secrets (server will NOT start without these)
SESSION_SECRET=your_session_secret_key_min_32_chars
JWT_SECRET=your_jwt_secret_key_min_32_chars

# App Domain (used for Stripe redirects, email links, OAuth callbacks)
APP_DOMAIN=https://simpletonapp.com
# For local development: APP_DOMAIN=http://localhost:5000

# CORS: Comma-separated list of allowed origins for auth routes
ALLOWED_ORIGINS=https://simpletonapp.com

# Authentication — Social OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
TWITTER_CONSUMER_KEY=your_twitter_consumer_key
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret

# Gmail Integration (standard OAuth2 — replaces Replit connector)
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_REDIRECT_URI=https://simpletonapp.com/api/gmail/callback

# SendGrid (email notifications)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# AI Provider API Keys
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe (payments & subscriptions)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# News API
NEWS_API_KEY=your_news_api_key

# Deployment Settings
NODE_ENV=production
PORT=5000
